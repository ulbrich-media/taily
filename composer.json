{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "ulbrich-media/taily",
    "type": "library",
    "description": "Management application for helping shelters and organisations with the animal mediation process.",
    "keywords": ["taily", "animal-shelter"],
    "license": "AGPL-3.0-only",
    "authors": [
        {
            "name": "Marcel Ulbrich",
            "email": "marcel@ulbrich.media"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.2",
        "laravel/tinker": "^2.10.1",
        "opis/json-schema": "^2.6",
        "spatie/laravel-medialibrary": "^11.20"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.6",
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.3",
        "psalm/plugin-laravel": "^4.0@RC",
        "vimeo/psalm": "^7.0@beta"
    },
    "autoload": {
        "psr-4": {
            "Taily\\": "api/src/",
            "Database\\Factories\\": "api/database/factories/",
            "Database\\Seeders\\": "api/database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Taily\\Tests\\": "api/tests/"
        }
    },
    "scripts": {
        "setup": "sh -c 'composer install && ([ -f api/.env ] || cp api/.env.example api/.env) && cd api && php artisan key:generate && php artisan migrate --force'",
        "format": "sh -c 'cd api && ./vendor/bin/pint --repair'",
        "flightcheck": [
            "@format",
            "@test"
        ],
        "test": "sh -c 'cd api && php artisan config:clear --ansi && php artisan test'",
        "ide-helper": "sh -c 'cd api && php artisan ide-helper:generate && php artisan ide-helper:models --nowrite && php artisan ide-helper:meta'",
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php api/artisan package:discover --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Taily\\Providers\\TailyServiceProvider"
            ],
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "vendor-dir": "api/vendor",
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "prefer-stable": true
}
